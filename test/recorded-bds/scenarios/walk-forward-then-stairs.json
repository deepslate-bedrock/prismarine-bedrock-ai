{
  "id": "walk-forward-then-stairs",
  "autoOp": true,
  "gamemode": "survival",
  "spawn": [0, 65, 0, 0, 0],
  "setupCommands": [
    "clear {player}",
    "time set day",
    "weather clear",
    "effect {player} clear",
    "fill -3 64 -2 3 72 16 air",
    "fill -3 63 -2 3 63 16 grass_block",

    "fill -1 64 6 1 64 6 oak_stairs[\"weirdo_direction\"=2]",
    "fill -1 64 7 1 64 7 oak_stairs[\"weirdo_direction\"=2]",
    "fill -1 65 8 1 65 8 oak_stairs[\"weirdo_direction\"=2]",
    "fill -1 65 9 1 65 9 oak_stairs[\"weirdo_direction\"=2]",
    "fill -1 66 10 1 66 10 oak_stairs[\"weirdo_direction\"=2]",
    "fill -1 66 11 1 66 11 oak_stairs[\"weirdo_direction\"=2]",

    "tp {player} 0 65 0 0 0"
  ],
  "steps": [
    {
      "id": "walk-forward-on-flat-ground",
      "instructions": [
        "Walk straight forward along the flat grass path.",
        "Stop near the base of the stairs."
      ],
      "clearance": {
        "type": "player_at",
        "position": [0, 65, 5],
        "radius": 1.25
      }
    },
    {
      "id": "walk-into-stairs",
      "instructions": [
        "Keep walking forward into the stairs.",
        "Let the player naturally climb up the stair blocks."
      ],
      "clearance": {
        "type": "player_at",
        "position": [0, 67, 11],
        "radius": 1.5
      }
    }
  ]
}